# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=hotel
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hotel_manager

# ── JWT (generate strong random secrets) ─────────────────
# Use: openssl rand -hex 32
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret

# ── AES-256 encryption key (exactly 32 hex chars = 16 bytes) ─
# Use: openssl rand -hex 16
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── App port (host port mapping) ─────────────────────────
APP_PORT=80
